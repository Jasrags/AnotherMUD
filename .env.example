# AnotherMUD configuration — copy to `.env` and edit.
#
#   cp .env.example .env
#
# `.env` is gitignored and loaded at startup by cmd/anothermud (internal/dotenv).
# The REAL environment always wins over this file, so an exported shell var
# overrides the same key here. Every value below is the engine default —
# uncomment and change only what you need. Durations use Go syntax
# (100ms, 3s, 5m, 24h); booleans accept 1/t/true/0/f/false.
#
# Point at a different file with ANOTHERMUD_ENV_FILE=/path/to/file.

# ── Core / networking ───────────────────────────────────────────────
# ANOTHERMUD_ADDR=:4000                       # telnet listen address
# ANOTHERMUD_WS_ADDR=                         # WebSocket listen address (empty = off)
# ANOTHERMUD_WS_PATH=/mud                     # WebSocket route
# ANOTHERMUD_WS_ORIGINS=                      # comma-separated allowed origins
# ANOTHERMUD_WS_INSECURE_SKIP_VERIFY=false    # skip WS origin check (dev only)
# NO_COLOR=                                   # set (non-empty) to disable ANSI color

# ── Content / world ─────────────────────────────────────────────────
# ANOTHERMUD_CONTENT_DIR=./content            # content pack root
# ANOTHERMUD_PACKS=starter-world              # active world pack(s); =wot for Wheel of Time
# ANOTHERMUD_SAVE_DIR=./saves                 # persistence root
# ANOTHERMUD_START_ROOM=starter-world:town-square
# ANOTHERMUD_START_HOUR=                      # in-game start hour 0-23 (unset = content default)
# ANOTHERMUD_DEFAULT_RACE=human
# ANOTHERMUD_DEFAULT_XP_TRACK=adventurer

# ── Logging ─────────────────────────────────────────────────────────
# ANOTHERMUD_LOG_LEVEL=info                   # debug|info|warn|error
# ANOTHERMUD_LOG_FORMAT=text                  # text|json

# ── Tick / scheduler cadences ───────────────────────────────────────
# ANOTHERMUD_TICK_INTERVAL=100ms
# ANOTHERMUD_COMBAT_CADENCE=3s
# ANOTHERMUD_AUTOSAVE_INTERVAL=30s
# ANOTHERMUD_IDLE_SWEEP_INTERVAL=30s
# ANOTHERMUD_SLOW_TICK_THRESHOLD=0            # 0 = disabled

# ── Combat ──────────────────────────────────────────────────────────
# ANOTHERMUD_FLEE_COOLDOWN=15s
# ANOTHERMUD_CRIT_MULTIPLIER=2
# ANOTHERMUD_NONPROFICIENT_PENALTY=4
# ANOTHERMUD_MASSIVE_DAMAGE_THRESHOLD=50
# ANOTHERMUD_MASSIVE_DAMAGE_DC=15
# ANOTHERMUD_UNARMED_SUBDUAL=true
# ANOTHERMUD_WHIP_ARMOR_THRESHOLD=1
# ANOTHERMUD_KITE_CHANCE=50                   # ranged-mob kite probability (%)
# ANOTHERMUD_RANGE_FALLOFF=2
# ANOTHERMUD_POINT_BLANK_PENALTY=4
# ANOTHERMUD_TWF_SECONDARY_OFFHAND_PENALTY=5
# ANOTHERMUD_SET_DAMAGE_BONUS=4
# ANOTHERMUD_CHAIN_CAP=10

# ── Movement / survival ─────────────────────────────────────────────
# ANOTHERMUD_MOVE_COST=2
# Ticks a slow-armor (medium/heavy) don/doff occupies you out of combat
# (action-economy.md §7.2). 30 ≈ 3s at the 100ms baseline tick.
# ANOTHERMUD_DON_TICKS=30
# ANOTHERMUD_SUSTENANCE_DRAIN_INTERVAL=30s
# ANOTHERMUD_SUSTENANCE_DRAIN_AMOUNT=1
# ANOTHERMUD_FORAGE_COOLDOWN=30s

# ── Corpses / campfires / biomes ────────────────────────────────────
# ANOTHERMUD_CORPSE_OWNERSHIP_WINDOW=60s
# ANOTHERMUD_CORPSE_LIFETIME=5m
# ANOTHERMUD_CORPSE_DECAY_INTERVAL=3s
# ANOTHERMUD_CAMPFIRE_LIFETIME=10m
# ANOTHERMUD_CAMPFIRE_DECAY_INTERVAL=5s
# ANOTHERMUD_BIOME_AMBIENCE_INTERVAL=90s

# ── The One Power (WoT) ─────────────────────────────────────────────
# ANOTHERMUD_AFFINITY_WEAK_FACTOR=0.5
# ANOTHERMUD_ANGREAL_PER_POINT=0.25
# ANOTHERMUD_SPEND_ON_SUCCESS=false
# ANOTHERMUD_CHANNEL_RESERVE_MULTIPLE=1
# ANOTHERMUD_MADNESS_PER_CAST=1
# ANOTHERMUD_MADNESS_OVERCHANNEL=3
# ANOTHERMUD_MADNESS_DECAY=1
# ANOTHERMUD_MADNESS_THRESHOLD=25
# ANOTHERMUD_MADNESS_CHANCE_DENOM=200
# ANOTHERMUD_MENTAL_STABILITY_THRESHOLD=25

# ── Reputation / faction feats ──────────────────────────────────────
# ANOTHERMUD_LOW_PROFILE_FACTOR=0.5

# ── Auction house ───────────────────────────────────────────────────
# ANOTHERMUD_AUCTION_LISTING_FEE=10
# ANOTHERMUD_AUCTION_SALE_CUT_PCT=5
# ANOTHERMUD_AUCTION_DURATION=24h
# ANOTHERMUD_AUCTION_MIN_PRICE=1
# ANOTHERMUD_AUCTION_PER_SELLER_CAP=10
# ANOTHERMUD_AUCTION_PAGE_SIZE=10
# ANOTHERMUD_AUCTION_SWEEP_INTERVAL=1m

# ── Roles / login ───────────────────────────────────────────────────
# ANOTHERMUD_ROLE_SEED=                       # "name:role,role;name:role"
# ANOTHERMUD_GRANTING_ROLE=admin
# ANOTHERMUD_ADMIN_ROLE=admin
# ANOTHERMUD_RESERVED_NAMES=                  # comma-separated; overrides built-in set
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT=60s
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_NAME=         # per-phase override (falls back to global)
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_EMAIL=
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_PASSWORD=

# ── Link-dead handling ──────────────────────────────────────────────
# ANOTHERMUD_LINKDEAD_ENABLED=true
# ANOTHERMUD_LINKDEAD_TIMEOUT=                # e.g. 5m (unset = session default)
# ANOTHERMUD_LINKDEAD_SWEEP_INTERVAL=30s
