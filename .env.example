# AnotherMUD configuration — copy to `.env` and edit.
#
#   cp .env.example .env
#
# `.env` is gitignored and loaded at startup by cmd/anothermud (internal/dotenv).
# The REAL environment always wins over this file, so an exported shell var
# overrides the same key here. Every value below is the engine default —
# uncomment and change only what you need. Durations use Go syntax
# (100ms, 3s, 5m, 24h); booleans accept 1/t/true/0/f/false.
#
# Point at a different file with ANOTHERMUD_ENV_FILE=/path/to/file.

# ── Core / networking ───────────────────────────────────────────────
# ANOTHERMUD_ADDR=:4000                       # telnet listen address
# WebSocket listener for the browser client (clients/web). Empty = off. The
# `make run-web` / `make watch-web` targets set this to :4001 for you; or enable
# it for any run/watch target with `make run WS_ADDR=:4001`.
# ANOTHERMUD_WS_ADDR=                         # WebSocket listen address (empty = off)
# ANOTHERMUD_WS_PATH=/mud                     # WebSocket route
# ANOTHERMUD_WS_ORIGINS=                      # comma-separated allowed origins (prod)
# Skip the WS origin check so a browser opened from file:// (origin null) can
# connect — DEV ONLY; in production set ANOTHERMUD_WS_ORIGINS instead. The
# run-web / watch-web make targets enable this.
# ANOTHERMUD_WS_INSECURE_SKIP_VERIFY=false    # skip WS origin check (dev only)
# How many rooms out the Room.Map GMCP neighbourhood reaches (web-client P2 — the
# walkable map a rich client draws). 0 (default) = the WHOLE AREA, matching the
# in-game `map` verb; a positive value bounds it (useful for a very large area
# where a whole-area frame on every move would be heavy).
# ANOTHERMUD_ROOM_MAP_RADIUS=0
# NO_COLOR=                                   # set (non-empty) to disable ANSI color

# ── Content / world ─────────────────────────────────────────────────
# ANOTHERMUD_CONTENT_DIR=./content            # content pack root
# ANOTHERMUD_PACKS=starter-world              # active world pack(s); =wot for Wheel of Time
# ANOTHERMUD_SAVE_DIR=./saves                 # persistence root
# ANOTHERMUD_START_ROOM=starter-world:town-square
# ANOTHERMUD_START_HOUR=                      # in-game start hour 0-23 (unset = content default)
# ANOTHERMUD_DEFAULT_RACE=human
# ANOTHERMUD_DEFAULT_XP_TRACK=adventurer

# ── Logging ─────────────────────────────────────────────────────────
# ANOTHERMUD_LOG_LEVEL=info                   # debug|info|warn|error
# ANOTHERMUD_LOG_FORMAT=text                  # text|json

# ── Tick / scheduler cadences ───────────────────────────────────────
# ANOTHERMUD_TICK_INTERVAL=100ms
# ANOTHERMUD_COMBAT_CADENCE=3s
# How often the transit state machine steps (elevators/conveyances, transit.md).
# One "step" of a line's travel/dwell/warn timing = one firing at this cadence.
# ANOTHERMUD_TRANSIT_CADENCE=1s
# ANOTHERMUD_AUTOSAVE_INTERVAL=30s
# ANOTHERMUD_IDLE_SWEEP_INTERVAL=30s
# ANOTHERMUD_SLOW_TICK_THRESHOLD=0            # 0 = disabled

# ── Skills ──────────────────────────────────────────────────────────
# Proficiency points between "You feel your <skill> improve." feedback lines
# (skills §3.5). Higher = fewer, more meaningful milestone messages; 1 = a line
# on every point. Values < 1 are coerced to 1.
# ANOTHERMUD_SKILL_GAIN_NOTIFY_STEP=10

# ── Combat ──────────────────────────────────────────────────────────
# ANOTHERMUD_FLEE_COOLDOWN=15s
# ANOTHERMUD_CRIT_MULTIPLIER=2
# ANOTHERMUD_NONPROFICIENT_PENALTY=4
# To-hit bonus when a worn smartlink pairs with a wielded smartgun weapon
# (item-modification smartlink↔smartgun pairing). 0 disables it.
# ANOTHERMUD_SMARTLINK_BONUS=2
# ANOTHERMUD_MASSIVE_DAMAGE_THRESHOLD=50
# ANOTHERMUD_MASSIVE_DAMAGE_DC=15
# ANOTHERMUD_UNARMED_SUBDUAL=true
# ANOTHERMUD_WHIP_ARMOR_THRESHOLD=1
# ANOTHERMUD_KITE_CHANCE=50                   # ranged-mob kite probability (%)
# ANOTHERMUD_RANGE_FALLOFF=2
# ANOTHERMUD_POINT_BLANK_PENALTY=4
# Range bands a Vision Magnification attacker (a cybereye grant) treats its
# target as closer, reducing the range falloff (ranged-combat §5.3). 0 disables.
# ANOTHERMUD_VISION_MAGNIFICATION_BANDS=1
# ANOTHERMUD_TWF_SECONDARY_OFFHAND_PENALTY=5
# ANOTHERMUD_SET_DAMAGE_BONUS=4
# ANOTHERMUD_CHAIN_CAP=10

# ── Security response / heat (security-response.md) ─────────────────
# The "law reacts to you" engine: a kill in a policed zone (an AREA's `security`
# tier AAA…Z) raises heat; crossing the tier threshold dispatches a timed patrol
# that spawns responders and hunts the offender. Runtime-only (no save). A world
# that sets no `security` tier (starter-world / WoT) never triggers it.
# ANOTHERMUD_SECURITY_ENABLED=true
# The mob template spawned to hunt an offender (fully-qualified). Defaults to the
# Shadowrun Knight Errant officer; harmless in other worlds (never spawned).
# ANOTHERMUD_SECURITY_RESPONDER=shadowrun:knight-errant-officer
# Heat removed from every tracked offender each sweep (higher = cools faster).
# ANOTHERMUD_SECURITY_DECAY=3
# Seconds between decay/response sweeps.
# ANOTHERMUD_SECURITY_SWEEP_SECONDS=1

# ── Movement / survival ─────────────────────────────────────────────
# ANOTHERMUD_MOVE_COST=2
# Ticks a slow-armor (medium/heavy) don/doff occupies you out of combat
# (action-economy.md §7.2). 30 ≈ 3s at the 100ms baseline tick.
# ANOTHERMUD_DON_TICKS=30
# Max members in a party, including the leader (grouping.md §7).
# ANOTHERMUD_PARTY_CAP=6
# Max hirelings a character may field at once (hireable-mobs.md §3.3). A small
# band by default; set to 1 for a single-companion game, or higher for larger
# bands (the per-hireling upkeep gold-sink is the counterweight).
# ANOTHERMUD_HIRELING_CAP=3
# How often hireling upkeep is charged; an owner who can't pay loses the
# hireling (hireable-mobs.md §7).
# ANOTHERMUD_HIRELING_UPKEEP_INTERVAL=5m
# Onboarding guide (onboarding-guide.md): the mob template materialized at a new
# character's side to trail them through their first rooms and depart at the
# graduation level. EMPTY (the default) disables the feature — a world opts in by
# naming its guide mob. The shadowrun make targets set this to shadowrun:street-guide.
# ANOTHERMUD_GUIDE_TEMPLATE=
# Character level at/above which the guide departs and no new guide appears.
# ANOTHERMUD_GUIDE_LEVEL_CAP=3
# First-entry commlink call (onboarding-guide.md): the fixer NPC whose
# `commlink_welcome` property is pinged to a new runner the moment they're
# in-world carrying a commlink (device-gated, shown once). EMPTY (the default)
# disables it. The shadowrun make targets set this to shadowrun:fixer-mentor.
# ANOTHERMUD_COMMLINK_FIXER=
# ANOTHERMUD_SUSTENANCE_DRAIN_INTERVAL=30s
# ANOTHERMUD_SUSTENANCE_DRAIN_AMOUNT=1
# ANOTHERMUD_FORAGE_COOLDOWN=30s

# ── Corpses / campfires / biomes ────────────────────────────────────
# ANOTHERMUD_CORPSE_OWNERSHIP_WINDOW=60s
# ANOTHERMUD_CORPSE_LIFETIME=5m
# ANOTHERMUD_CORPSE_DECAY_INTERVAL=3s
# ANOTHERMUD_CAMPFIRE_LIFETIME=10m
# ANOTHERMUD_CAMPFIRE_DECAY_INTERVAL=5s
# How long a spent ammunition clip ejected to the ground lingers (recoverable)
# before it decays (ammo-and-reloading §7). Swept at the corpse-decay cadence.
# ANOTHERMUD_EJECTED_HOLDER_LIFETIME=3m
# How long a firearm reload takes as a busy action (ammo-and-reloading §9):
# inserting/filling a clip. 0 = instant (no busy action).
# ANOTHERMUD_RELOAD_DURATION=1s
# Autoreload (autoreload.md §7): master switch for the per-character auto-reload-
# on-dry preference. false disables it server-wide regardless of a character's
# `autoreload on`.
# ANOTHERMUD_AUTORELOAD_ENABLED=true
# Minimum interval between a character's repeated "nothing to reload with"
# autoreload notices (autoreload.md §5). 0 = notify on every dry attempt.
# ANOTHERMUD_AUTORELOAD_NOAMMO_WINDOW=3s
# ANOTHERMUD_BIOME_AMBIENCE_INTERVAL=90s
# Interval between biome ambient-hazard ticks (area-effects.md §4.6): how often a
# `toxic`/`ashfall`-style biome damages unprotected creatures present (Glow City
# radiation, Puyallup ash fumes). Lower = harsher. Derived from content, not saved.
# ANOTHERMUD_BIOME_HAZARD_INTERVAL=6s

# ── The One Power (WoT) ─────────────────────────────────────────────
# ANOTHERMUD_AFFINITY_WEAK_FACTOR=0.5
# ANOTHERMUD_ANGREAL_PER_POINT=0.25
# ANOTHERMUD_SPEND_ON_SUCCESS=false
# ANOTHERMUD_CHANNEL_RESERVE_MULTIPLE=1
# ANOTHERMUD_MADNESS_PER_CAST=1
# ANOTHERMUD_MADNESS_OVERCHANNEL=3
# ANOTHERMUD_MADNESS_DECAY=1
# ANOTHERMUD_MADNESS_THRESHOLD=25
# ANOTHERMUD_MADNESS_CHANCE_DENOM=200
# ANOTHERMUD_MENTAL_STABILITY_THRESHOLD=25

# ── Reputation / faction feats ──────────────────────────────────────
# ANOTHERMUD_LOW_PROFILE_FACTOR=0.5
# Renown check difficulty for the look-at-player recognition note (reputation.md
# §6). Effective renown ≥ this is reliably recognized; below needs a high d20.
# ANOTHERMUD_RECOGNITION_DIFFICULTY=100

# ── Auction house ───────────────────────────────────────────────────
# ANOTHERMUD_AUCTION_LISTING_FEE=10
# ANOTHERMUD_AUCTION_SALE_CUT_PCT=5
# ANOTHERMUD_AUCTION_DURATION=24h
# ANOTHERMUD_AUCTION_MIN_PRICE=1
# ANOTHERMUD_AUCTION_PER_SELLER_CAP=10
# ANOTHERMUD_AUCTION_PAGE_SIZE=10
# ANOTHERMUD_AUCTION_SWEEP_INTERVAL=1m

# ── Roles / login ───────────────────────────────────────────────────
# ANOTHERMUD_ROLE_SEED=                       # "name:role,role;name:role"
# ANOTHERMUD_GRANTING_ROLE=admin
# ANOTHERMUD_ADMIN_ROLE=admin
# ANOTHERMUD_RESERVED_NAMES=                  # comma-separated; overrides built-in set
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT=60s
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_NAME=         # per-phase override (falls back to global)
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_EMAIL=
# ANOTHERMUD_LOGIN_IDLE_TIMEOUT_PASSWORD=

# ── Link-dead handling ──────────────────────────────────────────────
# ANOTHERMUD_LINKDEAD_ENABLED=true
# ANOTHERMUD_LINKDEAD_TIMEOUT=                # e.g. 5m (unset = session default)
# ANOTHERMUD_LINKDEAD_SWEEP_INTERVAL=30s
